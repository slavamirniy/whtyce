    "public",
    "src"
  ],
  "dependencies": {
    "canvas": "^3.2.1",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodejs-whisper": "^0.2.9",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
