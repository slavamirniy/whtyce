{
  "name": "whtyce",
  "version": "1.1.0",
  "description": "Mobile terminal with voice input — run a command, get a link",
  "main": "dist/server.js",
  "bin": {
    "whtyce": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "postinstall": "node dist/postinstall.js"
  },
